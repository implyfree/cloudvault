# Database (matches docker-compose postgres)
DATABASE_URL=postgresql://cloudvault:localdev@localhost:5433/cloudvault

# Server
PORT=3001

# Auth (change in production)
JWT_SECRET=dev-jwt-secret-change-in-production
ADMIN_PASSWORD=admin

# Optional: encryption for stored credentials (64-char hex or leave unset to derive from JWT_SECRET)
# ENCRYPTION_KEY=

# Optional: GCP / AWS / Azure - only needed if you use those providers
# GCP_SERVICE_ACCOUNT_JSON=path/to/key.json
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_STORAGE_CONNECTION_STRING=
